# AI Email Response System - Environment Variables (Example)
# Copy this file to .env and fill in your API keys if using cloud fallback

# OpenAI API Key (optional - for fallback when LM Studio unavailable)
OPENAI_API_KEY=your_openai_api_key_here

# Anthropic API Key (optional - for fallback when LM Studio unavailable)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# LM Studio Configuration (primary inference endpoint)
LM_STUDIO_URL=http://127.0.0.1:1234/v1

# Cloud Fallback Provider (optional: "openai", "anthropic", or leave empty)
FALLBACK_PROVIDER=

# Configuration File Path (default: config.yaml)
CONFIG_PATH=config.yaml
